# Google PageSpeed Insights API (gratis, dapetin di:
# https://developers.google.com/speed/docs/insights/v5/get-started)
PAGESPEED_API_KEY=

# Claude API key (untuk AI Analyst layer)
# By IdinCode
IDINCODE_API=

# ============================================================
# CRM Webhooks (v3.4) — OPSIONAL.
# Aktif HANYA kalau lo set salah satu URL di bawah + jalanin `python run.py --crm`.
# URL = incoming webhook (native automation / Zapier / Make / Airtable Web API).
# ============================================================
CRM_HUBSPOT_WEBHOOK_URL=
CRM_PIPEDRIVE_WEBHOOK_URL=
CRM_SALESFORCE_WEBHOOK_URL=
CRM_AIRTABLE_WEBHOOK_URL=
CRM_ZOHO_WEBHOOK_URL=
# Generic boleh banyak endpoint, pisah pakai koma:
CRM_GENERIC_WEBHOOK_URL=
# Opsional: header Authorization yang dikirim ke semua webhook (mis. "Bearer xxx")
CRM_WEBHOOK_AUTH_HEADER=
# Opsional: timeout detik (default 15)
CRM_WEBHOOK_TIMEOUT=
